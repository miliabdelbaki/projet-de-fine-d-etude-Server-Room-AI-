# Example backend environment variables
# Copy to .env and fill values for your environment

# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net

# Nom de la base de données utilisée par l'application (optionnel)
# Par défaut le serveur utilise 'ServerRoom'
MONGO_DB_NAME=ServerRoom

# CORS origins (comma-separated)
# e.g. CORS_ORIGIN=http://localhost:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# Frontend client URL for links in emails
CLIENT_URL=http://localhost:3000

# SMTP (leave default to disable sending emails in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-smtp-password

# Renommez ce fichier en .env et remplissez les valeurs
PORT=4000
MONGODB_URI="mongodb+srv://<mili>:<Mili2002.>@cluster0.xxxxx.mongodb.net/loeni?retryWrites=true&w=majority&appName=Cluster0"

# JWT
JWT_SECRET=change_me_long_random_32chars_min
JWT_EXPIRES=7d

# CORS (séparez par virgule si plusieurs origines)
CORS_ORIGIN=*

# URLs publiques
API_PUBLIC_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# SMTP (Mailtrap conseillé en dev)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=<user>
SMTP_PASS=<pass>
MAIL_FROM="Loeni <no-reply@loeni.app>"
