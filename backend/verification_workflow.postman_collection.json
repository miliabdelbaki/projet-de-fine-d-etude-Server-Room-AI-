              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Register Tech - Status 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Technicien créé (approved: false)\", function () {",
                  "    pm.expect(jsonData.user.role).to.equal(\"technicien\");",
                  "    pm.expect(jsonData.user.approved).to.equal(false);",
                  "});",
                  "",
                  "pm.environment.set(\"tech_id\", jsonData.user.id);"
                ]
              }
            }
