{
  "info": {
    "_postman_id": "verification-workflow-collection",
    "name": "Verification Workflow Complete",
    "description": "Collection complète : Admin & Technicien - Vérification avec photos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@postman.com\",\n  \"password\": \"Admin123456\",\n  \"displayName\": \"Admin Postman\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Register Admin - Status 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Admin créé avec token\", function () {",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.expect(jsonData.user.role).to.equal(\"admin\");",
                  "});",
                  "",
                  "pm.environment.set(\"admin_jwt\", jsonData.token);",
                  "pm.environment.set(\"admin_id\", jsonData.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Register Technicien",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
