            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Checklist Salle Bureau\",\n  \"description\": \"Vérification complète d'une salle de bureau\",\n  \"items\": [\n    {\n      \"label\": \"Portes fermées et verrouillées\",\n      \"required\": true,\n      \"order\": 1\n    },\n    {\n      \"label\": \"Fenêtres fermées\",\n      \"required\": true,\n      \"order\": 2\n    },\n    {\n      \"label\": \"Lumières éteintes\",\n      \"required\": false,\n      \"order\": 3\n    },\n    {\n      \"label\": \"Climatisation arrêtée\",\n      \"required\": false,\n      \"order\": 4\n    },\n    {\n      \"label\": \"Bureau organisé\",\n      \"required\": false,\n      \"order\": 5\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/checklists",
              "host": ["{{base_url}}"],
              "path": ["checklists"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"checklist_id\", jsonData._id);"
                ]
              }
            }
          ]
        },
